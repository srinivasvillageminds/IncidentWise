# Copy this file to .env and edit. Real environment variables override these.
# .env is gitignored - never commit the real one.

# --- LLM (Ollama) ---------------------------------------------------------
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b
# OLLAMA_EMBED_MODEL=nomic-embed-text
# OLLAMA_NUM_CTX=8192

# --- Answer generation backend ----------------------------------------------
# "ollama" (default, fully local) or "openai" (quick tests; embeddings and
# retrieval still run through Ollama either way).
# CHAT_BACKEND=openai
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_MODELS=gpt-4o-mini,gpt-4o          (dropdown list)

# xAI / Grok (OpenAI-compatible; appears in dropdown+bench when key set)
# XAI_API_KEY=xai-...
# XAI_CHAT_MODEL=grok-3-mini
# XAI_MODELS=grok-3-mini

# --- OCR fallback for scanned pages ----------------------------------------
# off | ollama | openai   (also settable per-run: python ingest.py --ocr ollama)
# OCR_BACKEND=ollama

# Local VLM used when OCR_BACKEND=ollama.
# Best quality:            qwen3-vl:8b        (slow on CPU)
# Faster, doc-specialized: granite3.2-vision  (IBM 2B)
# OLLAMA_VLM_MODEL=granite3.2-vision

# OpenAI vision, used when OCR_BACKEND=openai. PUBLIC documents only.
# OPENAI_API_KEY=sk-...
# OPENAI_VLM_MODEL=gpt-4o-mini

# OCR_MAX_PAGES=40
# OCR_DPI=150

# --- Guardrails ---------------------------------------------------------------
# off | l1 (deterministic scope gate) | l2 (+ intent classifier) | l3 (+ guard model)
# The UI dropdown overrides this per question.
# GUARD_LEVEL=l1
# LLAMA_GUARD_MODEL=llama-guard3:1b   (for l3: ollama pull llama-guard3:1b)

# --- Retrieval --------------------------------------------------------------
# TOP_K=6
# WEAK_DISTANCE=0.65

# --- Paths -------------------------------------------------------------------
# SAFETY_CRAWLER_DIR=../safety-pdf-crawler
# CHROMA_DIR=./chroma_db
